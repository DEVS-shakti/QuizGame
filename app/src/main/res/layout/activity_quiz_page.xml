<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    tools:context=".QuizPage">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/space_l">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_l">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/back"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Back"
                        android:src="@drawable/back" />

                    <TextView
                        android:id="@+id/title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_m"
                        android:layout_weight="1"
                        android:text="Quiz Game"
                        android:textAppearance="@style/TextAppearance.QuizGame.Subtitle" />

                    <TextView
                        android:id="@+id/no"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1/10"
                        android:textAppearance="@style/TextAppearance.QuizGame.Body"
                        android:textStyle="bold" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="@dimen/space_m"
                    android:max="60"
                    android:progress="0"
                    android:progressTint="@color/brand_primary"
                    android:indeterminateTint="@color/brand_primary" />

                <TextView
                    android:id="@+id/quiz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_m"
                    android:text=""
                    android:textAppearance="@style/TextAppearance.QuizGame.Title" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="@dimen/space_l"
            android:orientation="vertical">

            <TextView
                android:id="@+id/oA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_option"
                android:clickable="true"
                android:layout_marginBottom="@dimen/space_m"
                android:text="A. "
                android:textAppearance="@style/TextAppearance.QuizGame.Body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/oB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_option"
                android:clickable="true"
                android:layout_marginBottom="@dimen/space_m"
                android:text="B. "
                android:textAppearance="@style/TextAppearance.QuizGame.Body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/oC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_option"
                android:clickable="true"
                android:layout_marginBottom="@dimen/space_m"
                android:text="C. "
                android:textAppearance="@style/TextAppearance.QuizGame.Body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/oD"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_option"
                android:clickable="true"
                android:text="D. "
                android:textAppearance="@style/TextAppearance.QuizGame.Body"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/next"
            style="@style/Widget.QuizGame.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_m"
            android:text="Next" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ly"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/brand_background"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textAppearance="@style/TextAppearance.QuizGame.Title"
            android:textColor="@color/brand_secondary"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:indeterminateTint="@color/brand_primary"
            android:progressTint="@color/brand_primary" />
    </LinearLayout>
</FrameLayout>
