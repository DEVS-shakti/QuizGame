<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.QuizGame.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/agu</item>
        <item name="android:textColor">@color/brand_on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.QuizGame.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/lobster</item>
        <item name="android:textColor">@color/brand_on_surface</item>
    </style>

    <style name="TextAppearance.QuizGame.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/brand_on_surface</item>
    </style>

    <style name="Widget.QuizGame.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/agu</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_on_primary</item>
        <item name="cornerRadius">@dimen/radius_m</item>
        <item name="android:paddingLeft">@dimen/space_l</item>
        <item name="android:paddingRight">@dimen/space_l</item>
    </style>

    <style name="Widget.QuizGame.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:fontFamily">@font/agu</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/brand_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/brand_on_surface</item>
        <item name="cornerRadius">@dimen/radius_m</item>
    </style>

    <style name="Widget.QuizGame.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/brand_surface</item>
        <item name="cardCornerRadius">@dimen/radius_l</item>
        <item name="cardElevation">@dimen/card_elevation</item>
    </style>
</resources>
